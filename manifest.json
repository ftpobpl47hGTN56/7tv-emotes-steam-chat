{
  "manifest_version": 3,
  "name": "Steam [7TV Emotes ] steamcommunity",
  "version": "1.0.2",
  "description": "Adds a 7TV emote picker to Steam chat with render emote codes as images",
  "permissions": ["storage"],
  "host_permissions": [
    "https://steamcommunity.com/*",
    "https://7tv.app/*",
    "https://store.steampowered.com/*",
     "https://steamcommunity.com/chat*",
    "https://7tv.io/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/stv-picker-7tvemt-bttn.svg"],
      "matches": ["https://steamcommunity.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://steamcommunity.com/chat*",
        "https://steamcommunity.com/id/*/friends*",
        "https://7tv.app/*",
        "https://store.steampowered.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Steam 7TV Emotes"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}